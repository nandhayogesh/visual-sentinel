# Visual Sentinel — Backend Environment Variables
# Copy this file to .env and fill in your API keys

# URLScan.io — https://urlscan.io/user/apikey
URLSCAN_API_KEY=

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Google Safe Browsing — https://console.cloud.google.com → Safe Browsing API
SAFEBROWSING_API_KEY=

# PhishTank — https://www.phishtank.com/api_info.php (register for free app key)
PHISHTANK_APP_KEY=

# Server port (default 3001 — matches Vite proxy config)
PORT=3001
