# Visual Sentinel — Backend Environment Variables
# Copy this file to .env and fill in your API keys

# URLScan.io — https://urlscan.io/user/apikey
URLSCAN_API_KEY=

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Google Safe Browsing — https://console.cloud.google.com → Safe Browsing API
SAFEBROWSING_API_KEY=

# Optional: PhishTank app key (service file exists but is not mandatory in default flow)
PHISHTANK_APP_KEY=

# OpenPhish uses the public feed and does not require an API key.

# Server port (default 3001 — matches Vite proxy config)
PORT=3001

# Redis connection (required for queue + durable jobs)
# Prefer REDIS_URL for managed platforms (Upstash/Redis Cloud/Railway Redis)
REDIS_URL=

# Optional granular Redis config when REDIS_URL is not set
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# API hardening defaults
CORS_ORIGIN=http://localhost:8080
BODY_LIMIT=32kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=60

# Worker settings
WORKER_CONCURRENCY=2
