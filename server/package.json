{
  "name": "visual-sentinel-server",
  "version": "1.0.0",
  "description": "Backend API server for Visual Sentinel — phishing detection with URLScan, VirusTotal, Safe Browsing, and OpenPhish",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "worker": "node worker.js",
    "dev:all": "concurrently \"node --watch index.js\" \"node --watch worker.js\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bullmq": "^5.58.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^8.1.0",
    "express": "^4.18.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "morgan": "^1.10.1",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0",
    "whois-json": "^2.0.5"
  }
}
